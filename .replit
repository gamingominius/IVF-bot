# Use Node.js 18 or higher
modules = ["nodejs-18"]

# Run command for your bot
run = "node index.js"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["npm", "install"]
env = { "CI" = "true" }

[agent]
stack = "NODEJS"
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord Bot"

[[workflows.workflow]]
name = "Discord Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node artifacts/api-server/src/bot/index.js"

[workflows.workflow.metadata]
outputType = "console"

